{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASCEND Design Tokens",
  "version": "1.0.0",
  "description": "Single source of truth for all visual design decisions. CCO-locked palette and motion spec. Dark mode is default.",

  "color": {
    "raw": {
      "slate": {
        "950": "#050508",
        "900": "#0A0A0F",
        "800": "#14141F",
        "700": "#1E1E2E",
        "600": "#28283C",
        "500": "#35354E"
      },
      "pearl": {
        "50":  "#FDFCFA",
        "100": "#F4F1EA",
        "200": "#E8E4DC",
        "300": "#D5D0C6"
      },
      "oxide": {
        "300": "#E8886B",
        "400": "#D97055",
        "500": "#C75B39",
        "600": "#A84A2E",
        "700": "#8B3A22"
      },
      "gold": {
        "300": "#E8CE6F",
        "400": "#DFC04A",
        "500": "#D4AF37",
        "600": "#B8941E",
        "700": "#9A7A14"
      },
      "graphite": {
        "300": "#9CA3AF",
        "400": "#6B7280",
        "500": "#4B5563",
        "600": "#374151"
      },
      "transparent": "transparent",
      "white": "#FFFFFF",
      "black": "#000000"
    },

    "semantic": {
      "dark": {
        "_comment": "Dark mode — default. Applied via :root or [data-theme='dark']",
        "surface": {
          "base":    "#0A0A0F",
          "raised":  "#14141F",
          "overlay": "#1E1E2E",
          "card":    "#14141F",
          "input":   "#1E1E2E"
        },
        "text": {
          "primary":   "#F4F1EA",
          "secondary": "#9CA3AF",
          "muted":     "#6B7280",
          "disabled":  "#35354E",
          "inverse":   "#0A0A0F",
          "accent":    "#C75B39",
          "gold":      "#D4AF37",
          "link":      "#D97055"
        },
        "border": {
          "subtle":  "#28283C",
          "default": "#35354E",
          "strong":  "#6B7280",
          "accent":  "#C75B39"
        },
        "accent": {
          "default": "#C75B39",
          "hover":   "#D97055",
          "active":  "#A84A2E",
          "subtle":  "#28181280"
        },
        "status": {
          "positive": "#4ADE80",
          "warning":  "#D4AF37",
          "negative": "#C75B39",
          "neutral":  "#6B7280"
        },
        "focus": "#D4AF37",
        "scrim": "rgba(5, 5, 8, 0.72)"
      },

      "light": {
        "_comment": "Light mode — secondary. Applied via [data-theme='light']",
        "surface": {
          "base":    "#F4F1EA",
          "raised":  "#FDFCFA",
          "overlay": "#FFFFFF",
          "card":    "#FFFFFF",
          "input":   "#FFFFFF"
        },
        "text": {
          "primary":   "#0A0A0F",
          "secondary": "#4B5563",
          "muted":     "#6B7280",
          "disabled":  "#D5D0C6",
          "inverse":   "#F4F1EA",
          "accent":    "#A84A2E",
          "gold":      "#9A7A14",
          "link":      "#A84A2E"
        },
        "border": {
          "subtle":  "#E8E4DC",
          "default": "#D5D0C6",
          "strong":  "#6B7280",
          "accent":  "#A84A2E"
        },
        "accent": {
          "default": "#A84A2E",
          "hover":   "#C75B39",
          "active":  "#8B3A22",
          "subtle":  "#C75B3914"
        },
        "status": {
          "positive": "#16A34A",
          "warning":  "#B8941E",
          "negative": "#A84A2E",
          "neutral":  "#4B5563"
        },
        "focus": "#B8941E",
        "scrim": "rgba(10, 10, 15, 0.48)"
      }
    }
  },

  "typography": {
    "family": {
      "ui":        ["Inter", "IBM Plex Sans", "system-ui", "sans-serif"],
      "narrative": ["Source Serif 4", "IBM Plex Serif", "Georgia", "serif"],
      "mono":      ["JetBrains Mono", "IBM Plex Mono", "Courier New", "monospace"]
    },
    "size": {
      "2xs":  { "px": 10, "rem": "0.625rem"  },
      "xs":   { "px": 11, "rem": "0.6875rem" },
      "sm":   { "px": 13, "rem": "0.8125rem" },
      "base": { "px": 16, "rem": "1rem"      },
      "md":   { "px": 18, "rem": "1.125rem"  },
      "lg":   { "px": 20, "rem": "1.25rem"   },
      "xl":   { "px": 24, "rem": "1.5rem"    },
      "2xl":  { "px": 30, "rem": "1.875rem"  },
      "3xl":  { "px": 36, "rem": "2.25rem"   },
      "4xl":  { "px": 48, "rem": "3rem"      },
      "5xl":  { "px": 60, "rem": "3.75rem"   }
    },
    "weight": {
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    },
    "leading": {
      "tight":   1.2,
      "snug":    1.35,
      "normal":  1.5,
      "relaxed": 1.65,
      "loose":   1.8
    },
    "tracking": {
      "tight":   "-0.02em",
      "normal":  "0em",
      "wide":    "0.04em",
      "widest":  "0.10em"
    },
    "roles": {
      "_comment": "Semantic pairings. Use these in components, not raw tokens.",
      "question-setup":      { "family": "narrative", "size": "md",   "leading": "relaxed", "weight": "regular" },
      "question-option":     { "family": "narrative", "size": "base", "leading": "relaxed", "weight": "regular" },
      "inner-monologue":     { "family": "narrative", "size": "sm",   "leading": "relaxed", "weight": "regular", "tracking": "wide" },
      "npc-dialogue":        { "family": "narrative", "size": "base", "leading": "relaxed", "weight": "regular" },
      "ui-label":            { "family": "ui",        "size": "xs",   "leading": "tight",   "weight": "medium",  "tracking": "widest" },
      "ui-body":             { "family": "ui",        "size": "sm",   "leading": "normal",  "weight": "regular" },
      "ui-heading":          { "family": "ui",        "size": "lg",   "leading": "tight",   "weight": "semibold" },
      "stat-value":          { "family": "mono",      "size": "sm",   "leading": "tight",   "weight": "medium"  },
      "consequence-tag":     { "family": "mono",      "size": "xs",   "leading": "tight",   "weight": "regular", "tracking": "wide" },
      "first-day-letter":    { "family": "narrative", "size": "md",   "leading": "loose",   "weight": "regular" }
    }
  },

  "motion": {
    "_comment": "CCO spec: 160–220ms ease-in-out. Text reveals via opacity only (never typewriter). No bounce. No spring.",
    "duration": {
      "instant":    "80ms",
      "fast":       "120ms",
      "base":       "160ms",
      "slow":       "220ms",
      "deliberate": "360ms",
      "scene":      "600ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "enter":   "cubic-bezier(0.0, 0, 0.2, 1)",
      "exit":    "cubic-bezier(0.4, 0, 1, 1)",
      "linear":  "linear"
    },
    "transitions": {
      "standard":    "var(--duration-base) var(--easing-default)",
      "fast":        "var(--duration-fast) var(--easing-default)",
      "reveal":      "var(--duration-slow) var(--easing-enter)",
      "dismiss":     "var(--duration-fast) var(--easing-exit)",
      "scene-enter": "var(--duration-scene) var(--easing-enter)"
    },
    "reducedMotion": {
      "_comment": "When prefers-reduced-motion is set: use duration-instant for all transitions, disable opacity fades that span >80ms",
      "override": "80ms linear"
    }
  },

  "spacing": {
    "_comment": "4px base unit. Used for padding, margin, gap. Also controls layout rhythm.",
    "0":  { "px": 0,   "rem": "0"       },
    "1":  { "px": 4,   "rem": "0.25rem" },
    "2":  { "px": 8,   "rem": "0.5rem"  },
    "3":  { "px": 12,  "rem": "0.75rem" },
    "4":  { "px": 16,  "rem": "1rem"    },
    "5":  { "px": 20,  "rem": "1.25rem" },
    "6":  { "px": 24,  "rem": "1.5rem"  },
    "8":  { "px": 32,  "rem": "2rem"    },
    "10": { "px": 40,  "rem": "2.5rem"  },
    "12": { "px": 48,  "rem": "3rem"    },
    "16": { "px": 64,  "rem": "4rem"    },
    "20": { "px": 80,  "rem": "5rem"    },
    "24": { "px": 96,  "rem": "6rem"    },
    "32": { "px": 128, "rem": "8rem"    },
    "40": { "px": 160, "rem": "10rem"   }
  },

  "radius": {
    "none": "0",
    "sm":   "2px",
    "base": "4px",
    "md":   "6px",
    "lg":   "8px",
    "xl":   "12px",
    "2xl":  "16px",
    "full": "9999px"
  },

  "shadow": {
    "_comment": "Shadows are dark and weighted — this is not a light airy UI. On dark backgrounds, shadows use deeper blacks.",
    "sm":       "0 1px 2px rgba(0, 0, 0, 0.35)",
    "base":     "0 2px 8px rgba(0, 0, 0, 0.45)",
    "lg":       "0 8px 24px rgba(0, 0, 0, 0.55)",
    "xl":       "0 16px 48px rgba(0, 0, 0, 0.65)",
    "glow-oxide": "0 0 20px rgba(199, 91, 57, 0.20)",
    "glow-gold":  "0 0 20px rgba(212, 175, 55, 0.20)",
    "inner":    "inset 0 1px 3px rgba(0, 0, 0, 0.40)"
  },

  "zIndex": {
    "base":    0,
    "raised":  10,
    "overlay": 100,
    "drawer":  200,
    "modal":   300,
    "toast":   400,
    "cursor":  999
  },

  "layout": {
    "maxWidth": {
      "question":  "680px",
      "narrative": "600px",
      "ui":        "960px",
      "panel":     "360px"
    },
    "breakpoint": {
      "sm":  "480px",
      "md":  "768px",
      "lg":  "1024px",
      "xl":  "1280px"
    }
  }
}
