{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2022"],
    "types": ["vitest/globals", "node"],
    "skipLibCheck": true
  },
  "include": ["tests"],
  "exclude": ["node_modules"]
}
